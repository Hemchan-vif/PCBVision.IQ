# ============================================================
# PCBVision.IQ
# YOLOv11 Optimized Training Pipeline
# ============================================================

!nvidia-smi

import os
import glob

from IPython.display import Image as IPyImage
from IPython.display import display

# ============================================================
# Environment Information
# ============================================================

WORKSPACE_ROOT = os.getcwd()

print("Workspace:", WORKSPACE_ROOT)

!pip list | grep torch

# ============================================================
# Framework Validation
# ============================================================

# !pip install "ultralytics<=8.3.40"

import ultralytics

ultralytics.checks()

# ============================================================
# Dataset Configuration
# ============================================================

DATASET_CONFIG = os.path.join(
    WORKSPACE_ROOT,
    "dataset",
    "data.yaml"
)

TEST_IMAGE_DIRECTORY = os.path.join(
    WORKSPACE_ROOT,
    "dataset",
    "test",
    "images"
)

print("Dataset Config :", DATASET_CONFIG)
print("Test Images    :", TEST_IMAGE_DIRECTORY)

# ============================================================
# Model Configuration
# ============================================================

MODEL_WEIGHTS = "yolo11n.pt"

EPOCHS = 100

BATCH_SIZE = 16

IMAGE_SIZE = 640

CONFIDENCE_THRESHOLD = 0.25

# ============================================================
# Training
# ============================================================

!yolo task=detect \
mode=train \
model={MODEL_WEIGHTS} \
data={DATASET_CONFIG} \
epochs={EPOCHS} \
batch={BATCH_SIZE} \
imgsz={IMAGE_SIZE} \
plots=True

# ============================================================
# Training Outputs
# ============================================================

TRAIN_DIRECTORY = os.path.join(
    WORKSPACE_ROOT,
    "runs",
    "detect",
    "train"
)

!ls {TRAIN_DIRECTORY}

# ============================================================
# Confusion Matrix
# ============================================================

IPyImage(
    filename=os.path.join(
        TRAIN_DIRECTORY,
        "confusion_matrix.png"
    ),
    width=600
)

# ============================================================
# Training Results
# ============================================================

IPyImage(
    filename=os.path.join(
        TRAIN_DIRECTORY,
        "results.png"
    ),
    width=600
)

# ============================================================
# Validation Predictions
# ============================================================

IPyImage(
    filename=os.path.join(
        TRAIN_DIRECTORY,
        "val_batch0_pred.jpg"
    ),
    width=600
)

# ============================================================
# Validation
# ============================================================

BEST_MODEL_PATH = os.path.join(
    TRAIN_DIRECTORY,
    "weights",
    "best.pt"
)

!yolo task=detect \
mode=val \
model={BEST_MODEL_PATH} \
data={DATASET_CONFIG}

# ============================================================
# Inference
# ============================================================

!yolo task=detect \
mode=predict \
model={BEST_MODEL_PATH} \
conf={CONFIDENCE_THRESHOLD} \
source={TEST_IMAGE_DIRECTORY} \
save=True

# ============================================================
# Display Prediction Samples
# ============================================================

prediction_directories = glob.glob(
    os.path.join(
        WORKSPACE_ROOT,
        "runs",
        "detect",
        "predict*"
    )
)

latest_prediction_directory = max(
    prediction_directories,
    key=os.path.getmtime
)

prediction_images = glob.glob(
    os.path.join(
        latest_prediction_directory,
        "*.jpg"
    )
)

for image_file in prediction_images[:3]:

    display(
        IPyImage(
            filename=image_file,
            width=600
        )
    )

    print()

# ============================================================
# Training Summary
# ============================================================

print("=" * 60)
print("PCBVision.IQ optimized training completed.")
print("=" * 60)

print(f"Model                 : {MODEL_WEIGHTS}")
print(f"Epochs                : {EPOCHS}")
print(f"Batch Size            : {BATCH_SIZE}")
print(f"Image Size            : {IMAGE_SIZE}")
print(f"Confidence Threshold  : {CONFIDENCE_THRESHOLD}")
print(f"Best Model            : {BEST_MODEL_PATH}")