# ============================================================
# Image Preparation
# ============================================================

def prepare_images(
    source_directory,
    destination_directory
):

    os.makedirs(
        destination_directory,
        exist_ok=True
    )

    total_processed = 0

    for filename in os.listdir(
        source_directory
    ):

        if "_temp" not in filename:
            continue

        source_path = os.path.join(
            source_directory,
            filename
        )

        cleaned_filename = filename.replace(
            "_temp",
            ""
        )

        destination_path = os.path.join(
            destination_directory,
            cleaned_filename
        )

        shutil.copy(
            source_path,
            destination_path
        )

        total_processed += 1

        print(
            f"Processed: {cleaned_filename}"
        )

    print(
        f"Images prepared: {total_processed}"
    )


# ============================================================
# Annotation Conversion
# ============================================================

def convert_annotations_to_yolo(
    annotation_directory,
    output_directory,
    image_width,
    image_height
):

    os.makedirs(
        output_directory,
        exist_ok=True
    )

    converted_files = 0

    for file_name in os.listdir(
        annotation_directory
    ):

        if not file_name.endswith(".txt"):
            continue

        annotation_path = os.path.join(
            annotation_directory,
            file_name
        )

        output_path = os.path.join(
            output_directory,
            file_name
        )

        with open(
            annotation_path,
            "r"
        ) as annotation_file:

            annotations = annotation_file.readlines()

        with open(
            output_path,
            "w"
        ) as output_file:

            for annotation in annotations:

                x1, y1, x2, y2, class_id = map(
                    int,
                    annotation.strip().split()
                )

                center_x = (x1 + x2) / 2
                center_y = (y1 + y2) / 2

                width = x2 - x1
                height = y2 - y1

                center_x /= image_width
                center_y /= image_height

                width /= image_width
                height /= image_height

                output_file.write(
                    f"{class_id} "
                    f"{center_x:.6f} "
                    f"{center_y:.6f} "
                    f"{width:.6f} "
                    f"{height:.6f}\n"
                )

        converted_files += 1

    print(
        f"Annotation files converted: {converted_files}"
    )


# ============================================================
# Dataset Summary
# ============================================================

def summarize_dataset():

    train_images = len(
        os.listdir(
            os.path.join(
                RAW_DATASET_DIRECTORY,
                "train",
