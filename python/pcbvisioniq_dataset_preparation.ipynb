    )

    valid_images = len(
        os.listdir(
            os.path.join(
                RAW_DATASET_DIRECTORY,
                "valid",
                "images"
            )
        )
    )

    test_images = len(
        os.listdir(
            os.path.join(
                RAW_DATASET_DIRECTORY,
                "test",
                "images"
            )
        )
    )

    print()
    print("Dataset Summary")
    print("-" * 40)
    print(f"Training Images   : {train_images}")
    print(f"Validation Images : {valid_images}")
    print(f"Test Images       : {test_images}")
    print("-" * 40)


# ============================================================
# Execute
# ============================================================

summarize_dataset()

print()
print("PCBVision.IQ dataset preparation completed.")