!pip install -q ultralytics

import os

from ultralytics import YOLO

# ============================================================
# Environment Information
# ============================================================

WORKSPACE_ROOT = os.getcwd()

print("Workspace:", WORKSPACE_ROOT)

# ============================================================
# Dataset Configuration
# ============================================================

DATASET_CONFIG = os.path.join(
    WORKSPACE_ROOT,
    "dataset",
    "data.yaml"
)

print("Dataset Config :", DATASET_CONFIG)

# ============================================================
# Model Configuration
# ============================================================

MODEL_WEIGHTS = "yolov10n.pt"

model = YOLO(
    MODEL_WEIGHTS
)

# ============================================================
# Training Parameters
# ============================================================

EPOCHS = 100

BATCH_SIZE = 32

IMAGE_SIZE = 640

ENABLE_PLOTS = True

# ============================================================
# Training
# ============================================================

results = model.train(
    data=DATASET_CONFIG,
    epochs=EPOCHS,
    batch=BATCH_SIZE,
    imgsz=IMAGE_SIZE,
    plots=ENABLE_PLOTS
)

# ============================================================
# Training Summary
# ============================================================

print("=" * 60)
print("PCBVision.IQ YOLOv10 benchmark completed.")
print("=" * 60)

print(f"Model        : {MODEL_WEIGHTS}")
print(f"Epochs       : {EPOCHS}")
print(f"Batch Size   : {BATCH_SIZE}")
print(f"Image Size   : {IMAGE_SIZE}")